generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Restaurant {
  id                       String                     @id @db.Char(36)
  name                     String                     @db.VarChar(200)
  slug                     String                     @unique(map: "uq_restaurant_slug") @db.VarChar(100)
  timezone                 String                     @default("UTC") @db.VarChar(64)
  isActive                 Boolean                    @default(true) @map("is_active")
  createdAt                DateTime                   @default(now()) @map("created_at")
  updatedAt                DateTime                   @default(now()) @updatedAt @map("updated_at")
  audit_log                audit_log[]
  batch_item               batch_item[]
  dine_in_session          dine_in_session[]
  domain_outbox            domain_outbox[]
  idempotency_record       idempotency_record[]
  kitchen_batch            kitchen_batch[]
  menu_category            MenuCategory[]
  menu_item                MenuItem[]
  restaurant_daily_counter restaurant_daily_counter[]
  settings                 RestaurantSettings?
  tables                   RestaurantTable[]
  roms_order               roms_order[]
  staff_refresh_token      staff_refresh_token[]
  staff_request            staff_request[]
  users                    StaffUser[]
  table_qr_token           table_qr_token[]

  @@map("restaurant")
}

model RestaurantSettings {
  id                     String     @id @db.Char(36)
  restaurantId           String     @unique(map: "uq_restaurant_settings_restaurant") @map("restaurant_id") @db.Char(36)
  defaultCurrency        String     @map("default_currency") @db.Char(3)
  taxRateBps             Int        @default(0) @map("tax_rate_bps")
  serviceChargeBps       Int        @default(0) @map("service_charge_bps")
  sessionTokenTtlMinutes Int        @default(480) @map("session_token_ttl_minutes")
  allowQrOnReservedTable Boolean    @default(false) @map("allow_qr_on_reserved_table")
  paymentSoftLockEnabled Boolean    @default(true) @map("payment_soft_lock_enabled")
  createdAt              DateTime   @default(now()) @map("created_at")
  updatedAt              DateTime   @default(now()) @updatedAt @map("updated_at")
  restaurant             Restaurant @relation(fields: [restaurantId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_settings_restaurant")

  @@map("restaurant_settings")
}

model RestaurantTable {
  id              String            @id @db.Char(36)
  restaurantId    String            @map("restaurant_id") @db.Char(36)
  label           String            @db.VarChar(50)
  capacity        Int               @default(4) @db.SmallInt
  status          String            @default("available") @db.VarChar(20)
  sortOrder       Int               @default(0) @map("sort_order")
  isActive        Boolean           @default(true) @map("is_active")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @default(now()) @updatedAt @map("updated_at")
  dine_in_session dine_in_session[]
  restaurant      Restaurant        @relation(fields: [restaurantId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_table_restaurant")
  table_qr_token  table_qr_token?

  @@unique([restaurantId, label], map: "uq_table_label")
  @@index([restaurantId, status], map: "idx_table_restaurant_status")
  @@map("restaurant_table")
}

model StaffUser {
  id                                                            String                           @id @db.Char(36)
  restaurantId                                                  String                           @map("restaurant_id") @db.Char(36)
  email                                                         String                           @db.VarChar(255)
  displayName                                                   String                           @map("display_name") @db.VarChar(100)
  passwordHash                                                  String                           @map("password_hash") @db.VarChar(255)
  isActive                                                      Boolean                          @default(true) @map("is_active")
  lastLoginAt                                                   DateTime?                        @map("last_login_at")
  createdAt                                                     DateTime                         @default(now()) @map("created_at")
  updatedAt                                                     DateTime                         @default(now()) @updatedAt @map("updated_at")
  batch_item_status_history                                     batch_item_status_history[]
  delivery_detail                                               delivery_detail[]
  dine_in_session_dine_in_session_closed_by_user_idTostaff_user dine_in_session[]                @relation("dine_in_session_closed_by_user_idTostaff_user")
  dine_in_session_dine_in_session_opened_by_user_idTostaff_user dine_in_session[]                @relation("dine_in_session_opened_by_user_idTostaff_user")
  menu_item_availability_history                                menu_item_availability_history[]
  order_payment                                                 order_payment[]
  roms_order                                                    roms_order[]
  session_payment                                               session_payment[]
  staff_refresh_token                                           staff_refresh_token[]
  staff_request                                                 staff_request[]
  restaurant                                                    Restaurant                       @relation(fields: [restaurantId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_staff_restaurant")
  user_role                                                     user_role[]

  @@unique([restaurantId, email], map: "uq_staff_email")
  @@index([restaurantId], map: "idx_staff_restaurant")
  @@map("staff_user")
}

model Role {
  id              String            @id @db.Char(36)
  roleKey         String            @unique(map: "uq_role_key") @map("role_key") @db.VarChar(32)
  name            String            @db.VarChar(50)
  createdAt       DateTime          @default(now()) @map("created_at")
  user_role       user_role[]
  role_permission role_permission[]

  @@map("role")
}

/// Fine-grained capability keys (Flutter AppPermission.name).
model Permission {
  id              String            @id @db.Char(36)
  permissionKey   String            @unique(map: "uq_permission_key") @map("permission_key") @db.VarChar(64)
  name            String            @db.VarChar(100)
  createdAt       DateTime          @default(now()) @map("created_at")
  role_permission role_permission[]

  @@map("permission")
}

model role_permission {
  id            String     @id @db.Char(36)
  role_id       String     @db.Char(36)
  permission_id String     @db.Char(36)
  role          Role       @relation(fields: [role_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_role_permission_role")
  permission    Permission @relation(fields: [permission_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_role_permission_permission")

  @@unique([role_id, permission_id], map: "uq_role_permission")
  @@index([permission_id], map: "idx_role_permission_permission")
  @@map("role_permission")
}

model MenuCategory {
  id           String     @id @db.Char(36)
  restaurantId String     @map("restaurant_id") @db.Char(36)
  name         String     @db.VarChar(100)
  sortOrder    Int        @default(0) @map("sort_order")
  isActive     Boolean    @default(true) @map("is_active")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @default(now()) @updatedAt @map("updated_at")
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_category_restaurant")
  items        MenuItem[]

  @@index([restaurantId, isActive, sortOrder], map: "idx_category_restaurant")
  @@map("menu_category")
}

model MenuItem {
  id                             String                           @id @db.Char(36)
  restaurantId                   String                           @map("restaurant_id") @db.Char(36)
  categoryId                     String                           @map("category_id") @db.Char(36)
  name                           String                           @db.VarChar(200)
  description                    String?                          @db.Text
  basePriceMinor                 BigInt                           @map("base_price_minor")
  currencyCode                   String                           @map("currency_code") @db.Char(3)
  availability                   String                           @default("available") @db.VarChar(32)
  imageUrl                       String?                          @map("image_url") @db.VarChar(500)
  sortOrder                      Int                              @default(0) @map("sort_order")
  isActive                       Boolean                          @default(true) @map("is_active")
  createdAt                      DateTime                         @default(now()) @map("created_at")
  updatedAt                      DateTime                         @default(now()) @updatedAt @map("updated_at")
  batch_item                     batch_item[]
  customization_group            customization_group[]
  category                       MenuCategory                     @relation(fields: [categoryId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_menu_item_category")
  restaurant                     Restaurant                       @relation(fields: [restaurantId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_menu_item_restaurant")
  menu_item_availability_history menu_item_availability_history[]
  order_line                     order_line[]
  session_cart_item              session_cart_item[]

  @@index([restaurantId, availability, isActive], map: "idx_menu_item_catalog")
  @@index([categoryId], map: "idx_menu_item_category")
  @@map("menu_item")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model audit_log {
  id            String     @id @db.Char(36)
  restaurant_id String     @db.Char(36)
  actor_type    String     @db.VarChar(32)
  actor_id      String?    @db.Char(36)
  entity_type   String     @db.VarChar(64)
  entity_id     String     @db.Char(36)
  action        String     @db.VarChar(32)
  before_json   Json?
  after_json    Json?
  metadata_json Json
  occurred_at   DateTime
  restaurant    Restaurant @relation(fields: [restaurant_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_audit_restaurant")

  @@index([restaurant_id, entity_type, entity_id], map: "idx_audit_entity")
  @@index([restaurant_id, occurred_at], map: "idx_audit_time")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model batch_item {
  id                        String                      @id @db.Char(36)
  batch_id                  String                      @db.Char(36)
  restaurant_id             String                      @db.Char(36)
  menu_item_id              String                      @db.Char(36)
