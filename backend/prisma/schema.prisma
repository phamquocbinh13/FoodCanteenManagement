// ROMS Prisma schema — mirrors docs/backend/sprint-0/04_schema_mysql8.sql
// Source of truth for DDL remains the SQL script (already applied in Workbench).
// After setting DATABASE_URL: npx prisma db pull  (to refresh from live DB)
//                           OR npx prisma generate (use this file)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Restaurant {
  id        String   @id @db.Char(36)
  name      String   @db.VarChar(200)
  slug      String   @unique @db.VarChar(100)
  timezone  String   @default("UTC") @db.VarChar(64)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.DateTime(3)

  settings RestaurantSettings?
  tables   RestaurantTable[]
  users    StaffUser[]

  @@map("restaurant")
}

model RestaurantSettings {
  id                       String   @id @db.Char(36)
  restaurantId             String   @unique @map("restaurant_id") @db.Char(36)
  defaultCurrency          String   @map("default_currency") @db.Char(3)
  taxRateBps               Int      @default(0) @map("tax_rate_bps")
  serviceChargeBps         Int      @default(0) @map("service_charge_bps")
  sessionTokenTtlMinutes   Int      @default(480) @map("session_token_ttl_minutes")
  allowQrOnReservedTable   Boolean  @default(false) @map("allow_qr_on_reserved_table")
  paymentSoftLockEnabled   Boolean  @default(true) @map("payment_soft_lock_enabled")
  createdAt                DateTime @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt                DateTime @updatedAt @map("updated_at") @db.DateTime(3)

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])

  @@map("restaurant_settings")
}

model RestaurantTable {
  id           String   @id @db.Char(36)
  restaurantId String   @map("restaurant_id") @db.Char(36)
  label        String   @db.VarChar(50)
  capacity     Int      @default(4) @db.SmallInt
  status       String   @default("available") @db.VarChar(20)
  sortOrder    Int      @default(0) @map("sort_order")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.DateTime(3)

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])

  @@unique([restaurantId, label], map: "uq_table_label")
  @@index([restaurantId, status], map: "idx_table_restaurant_status")
  @@map("restaurant_table")
}

model StaffUser {
  id           String    @id @db.Char(36)
  restaurantId String    @map("restaurant_id") @db.Char(36)
  email        String    @db.VarChar(255)
  displayName  String    @map("display_name") @db.VarChar(100)
  passwordHash String    @map("password_hash") @db.VarChar(255)
  isActive     Boolean   @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at") @db.DateTime(3)
  createdAt    DateTime  @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.DateTime(3)

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])

  @@unique([restaurantId, email], map: "uq_staff_email")
  @@index([restaurantId], map: "idx_staff_restaurant")
  @@map("staff_user")
}

model Role {
  id        String   @id @db.Char(36)
  roleKey   String   @unique @map("role_key") @db.VarChar(32)
  name      String   @db.VarChar(50)
  createdAt DateTime @default(now()) @map("created_at") @db.DateTime(3)

  @@map("role")
}

model MenuCategory {
  id           String   @id @db.Char(36)
  restaurantId String   @map("restaurant_id") @db.Char(36)
  name         String   @db.VarChar(100)
  sortOrder    Int      @default(0) @map("sort_order")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.DateTime(3)

  items MenuItem[]

  @@index([restaurantId, isActive, sortOrder], map: "idx_category_restaurant")
  @@map("menu_category")
}

model MenuItem {
  id             String   @id @db.Char(36)
  restaurantId   String   @map("restaurant_id") @db.Char(36)
  categoryId     String   @map("category_id") @db.Char(36)
  name           String   @db.VarChar(200)
  description    String?  @db.Text
  basePriceMinor BigInt   @map("base_price_minor")
  currencyCode   String   @map("currency_code") @db.Char(3)
  availability   String   @default("available") @db.VarChar(32)
  imageUrl       String?  @map("image_url") @db.VarChar(500)
  sortOrder      Int      @default(0) @map("sort_order")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.DateTime(3)

  category MenuCategory @relation(fields: [categoryId], references: [id])

  @@index([restaurantId, availability, isActive], map: "idx_menu_item_catalog")
  @@map("menu_item")
}
