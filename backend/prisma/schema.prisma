/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model roms_order {
  id                 String           @id @db.Char(36)
  restaurant_id      String           @db.Char(36)
  order_number       BigInt
  order_type         String           @db.VarChar(32)
  status             String           @default("draft") @db.VarChar(32)
  customer_name      String?          @db.VarChar(200)
  customer_phone     String?          @db.VarChar(30)
  notes              String?          @db.VarChar(500)
  created_by_user_id String           @db.Char(36)
  submitted_at       DateTime?
  completed_at       DateTime?
  created_at         DateTime         @default(now())
  updated_at         DateTime         @default(now())
  delivery_detail    delivery_detail?
  kitchen_batch      kitchen_batch[]
  order_line         order_line[]
  order_payment      order_payment?
  staff_user         StaffUser        @relation(fields: [created_by_user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_order_creator")
  restaurant         Restaurant       @relation(fields: [restaurant_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_order_restaurant")

  @@unique([restaurant_id, order_number], map: "uq_order_number")
  @@index([created_by_user_id], map: "fk_order_creator")
  @@index([restaurant_id, order_type, status], map: "idx_order_type_status")
}

model session_auth_token {
  id              String          @id @db.Char(36)
  session_id      String          @db.Char(36)
  token_hash      String          @unique(map: "uq_session_token_hash") @db.VarChar(128)
  expires_at      DateTime
  revoked_at      DateTime?
  created_at      DateTime        @default(now())
  dine_in_session dine_in_session @relation(fields: [session_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_session_token_session")

  @@index([session_id], map: "idx_session_token_session")
}

model session_bill_line {
  id                 String          @id @db.Char(36)
  session_payment_id String          @db.Char(36)
  batch_item_id      String          @db.Char(36)
  description        String          @db.VarChar(300)
  quantity           Int             @db.SmallInt
  unit_price_minor   BigInt
  line_total_minor   BigInt
  currency_code      String          @db.Char(3)
  created_at         DateTime        @default(now())
  batch_item         batch_item      @relation(fields: [batch_item_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_bill_line_batch_item")
  session_payment    session_payment @relation(fields: [session_payment_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_bill_line_payment")

  @@index([batch_item_id], map: "fk_bill_line_batch_item")
  @@index([session_payment_id], map: "idx_bill_line_payment")
}

