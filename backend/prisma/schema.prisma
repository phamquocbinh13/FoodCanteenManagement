  kitchen_batch             kitchen_batch               @relation(fields: [batch_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_batch_item_batch")
  menu_item                 MenuItem                    @relation(fields: [menu_item_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_batch_item_menu")
  restaurant                Restaurant                  @relation(fields: [restaurant_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_batch_item_restaurant")
  batch_item_customization  batch_item_customization[]
  batch_item_status_history batch_item_status_history[]
  session_bill_line         session_bill_line[]

  @@index([menu_item_id], map: "fk_batch_item_menu")
  @@index([batch_id], map: "idx_batch_item_batch")
  @@index([restaurant_id, status], map: "idx_batch_item_restaurant_status")
}

model batch_item_customization {
  id                     String     @id @db.Char(36)
  batch_item_id          String     @db.Char(36)
  group_key              String     @db.VarChar(64)
  group_name_snapshot    String     @db.VarChar(100)
  option_key             String?    @db.VarChar(64)
  option_name_snapshot   String?    @db.VarChar(100)
  value_json             Json
  price_delta_minor      BigInt     @default(0)
  currency_code          String     @db.Char(3)
  kitchen_label_rendered String     @db.VarChar(200)
  created_at             DateTime   @default(now())
  batch_item             batch_item @relation(fields: [batch_item_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_batch_custom_item")

  @@index([batch_item_id], map: "idx_batch_custom_item")
}

model batch_item_status_history {
  id                 String     @id @db.Char(36)
  batch_item_id      String     @db.Char(36)
  from_status        String?    @db.VarChar(32)
  to_status          String     @db.VarChar(32)
  changed_by_user_id String?    @db.Char(36)
