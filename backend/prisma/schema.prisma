  batch_item         batch_item @relation(fields: [batch_item_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_batch_status_item")
  staff_user         StaffUser? @relation(fields: [changed_by_user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_batch_status_user")

  @@index([changed_by_user_id], map: "fk_batch_status_user")
  @@index([batch_item_id, occurred_at], map: "idx_batch_status_hist")
}

