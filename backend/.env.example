# ROMS API — copy to .env and set your MySQL Workbench credentials
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# mysql://USER:PASSWORD@HOST:PORT/DATABASE
# Example (change password to match Workbench):
DATABASE_URL="mysql://root:YOUR_MYSQL_PASSWORD@localhost:3306/roms"

# Staff JWT (HS256)
JWT_SECRET="change-me-to-a-long-random-string"
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# CORS — Flutter web / local tools
CORS_ORIGINS="http://localhost:*,http://127.0.0.1:*"
